  m_Name: UIXBadge_StyleSheet
  m_EditorClassIdentifier: UIX.Runtime::UIX.Templates.UIXStyleSheet
  SourcePath: Packages/com.uix.framework/Components/BuiltIn/UIXBadge/UIXBadge.uss
  SourceUSS: '.uix-badge { padding: var(--spacing-xs) var(--spacing-sm); border-radius:
    var(--radius-full, 9999); }

    .uix-badge-default { background-color: #6C757D;
    }

    .uix-badge-success { background-color: #28A745; }

    .uix-badge-warning
    { background-color: #FFC107; color: #000; }

    .uix-badge-error { background-color:
    #DC3545; }

    .uix-badge-text { font-size: var(--font-size-xs, 12); color:
    #FFF; }

'
  Rules:
  - SelectorJson: 
    Properties:
    - Name: padding
      Value: var(--spacing-xs) var(--spacing-sm)
    - Name: border-radius
      Value: var(--radius-full, 9999)
    LineNumber: 1
  - SelectorJson: 
    Properties:
    - Name: background-color
      Value: '#28A745'
    LineNumber: 3
  - SelectorJson: 
    Properties:
    - Name: background-color
      Value: '#DC3545'
    LineNumber: 5
  Variables: []
