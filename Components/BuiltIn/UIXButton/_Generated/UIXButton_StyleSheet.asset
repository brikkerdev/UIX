  m_Script: {fileID: 11500000, guid: bcec11ccad78e00488c26d196427dd3a, type: 3}
  m_Name: UIXButton_StyleSheet
  m_EditorClassIdentifier: UIX.Runtime::UIX.Templates.UIXStyleSheet
  SourcePath: Packages/com.uix.framework/Components/BuiltIn/UIXButton/UIXButton.uss
  SourceUSS: ".uix-btn {\n    padding: var(--spacing-md);\n    background-color:
    var(--color-primary);\n    min-height: 36;\n}\n\n.uix-btn-primary { background-color:
    var(--color-primary); }\n.uix-btn-secondary { background-color: #6C757D; }\n.uix-btn-danger
    { background-color: #DC3545; }\n.uix-btn-ghost { background-color: transparent;
    }\n\n.uix-btn-sm { min-height: 28; padding: var(--spacing-xs); }\n.uix-btn-md
    { min-height: 36; }\n.uix-btn-lg { min-height: 44; padding: var(--spacing-lg);
    }\n\n.uix-btn-content { gap: var(--spacing-sm); align-items: center; }\n.uix-btn-text
    { color: var(--color-on-primary, #FFFFFF); font-size: var(--font-size-md); }\n.uix-btn-icon
    { width: 20; height: 20; }\n"
