  m_Script: {fileID: 11500000, guid: bcec11ccad78e00488c26d196427dd3a, type: 3}
  m_Name: UIXSlider_StyleSheet
  m_EditorClassIdentifier: UIX.Runtime::UIX.Templates.UIXStyleSheet
  SourcePath: Packages/com.uix.framework/Components/BuiltIn/UIXSlider/UIXSlider.uss
  SourceUSS: '.uix-slider { gap: var(--spacing-xs); }

    .uix-slider-label { font-size:
    var(--font-size-sm, 14); }

    .uix-slider-row { gap: var(--spacing-sm); align-items:
    center; }

    .uix-slider-control { flex: 1; min-width: 100; }

    .uix-slider-value
    { min-width: 40; font-size: var(--font-size-sm, 14); }

'
