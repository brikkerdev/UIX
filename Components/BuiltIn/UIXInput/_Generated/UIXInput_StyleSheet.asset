  m_Script: {fileID: 11500000, guid: bcec11ccad78e00488c26d196427dd3a, type: 3}
  m_Name: UIXInput_StyleSheet
  m_EditorClassIdentifier: UIX.Runtime::UIX.Templates.UIXStyleSheet
  SourcePath: Packages/com.uix.framework/Components/BuiltIn/UIXInput/UIXInput.uss
  SourceUSS: '.uix-input { gap: var(--spacing-xs); }

    .uix-input-label { font-size:
    var(--font-size-sm, 14); color: var(--color-text-muted, #666); }

    .uix-input-field
    { min-height: 36; padding: var(--spacing-sm); background-color: var(--color-surface,
    #FFF); border-radius: var(--radius-sm, 4); }

'
  Rules:
  - SelectorJson: 
    Properties:
    - Name: gap
      Value: var(--spacing-xs)
    LineNumber: 1
  - SelectorJson: 
    Properties:
    - Name: min-height
      Value: 36
    - Name: padding
      Value: var(--spacing-sm)
    - Name: background-color
      Value: var(--color-surface, #FFF)
    - Name: border-radius
      Value: var(--radius-sm, 4)
    LineNumber: 3
