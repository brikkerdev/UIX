    "path": "Documentation~"
  },
  "keywords": [
    "UI",
    "UIX",
    "XML",
    "USS",
    "declarative",
    "uGUI",
    "UACF"
  ],
  "category": "UI",
  "dependencies": {
    "com.uacf.editor": "1.0.0",
    "com.unity.ugui": "1.0.0",
    "com.unity.textmeshpro": "3.0.0"
  },
  "samples": [
    {
      "displayName": "Basic Setup",
      "description": "Button, Text, Card components and SampleScreen",
      "path": "Samples~/BasicSetup"
    },
    {
      "displayName": "Full Demo",
      "description": "LightTheme, DarkTheme, ThemeDemo, ComponentsDemo, NavigationDemo",
      "path": "Samples~/FullDemo"
    }
  ]
}
